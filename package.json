{
  "name": "hachiko",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "docs:api": "tsx scripts/export-openapi.ts",
    "audit": "pnpm audit --audit-level=moderate",
    "audit:full": "pnpm audit --audit-level=low",
    "deps:check": "pnpm outdated"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@neondatabase/serverless": "1.1.0",
    "@prisma/client": "6.19.3",
    "@tanstack/react-query": "^5.101.2",
    "argon2": "0.44.0",
    "date-fns": "^4.4.0",
    "iron-session": "8.0.4",
    "jose": "6.2.3",
    "mercadopago": "3.2.0",
    "otpauth": "^9.5.1",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.81.0",
    "resend": "6.17.2",
    "transbank-sdk": "6.1.1",
    "zod": "4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "next": "16.2.10",
    "playwright": "^1.61.1",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "prisma": "6.19.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "rollup@>=3.0.0 <3.30.0": "^3.30.0",
      "postcss@8.4.31": "^8.5.10",
      "uuid": "^11.1.1",
      "form-data": "^4.0.6"
    }
  }
}
