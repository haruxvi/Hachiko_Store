{
  "name": "hachiko",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "docs:api": "tsx scripts/export-openapi.ts",
    "audit": "pnpm audit --audit-level=moderate",
    "audit:full": "pnpm audit --audit-level=low",
    "deps:check": "pnpm outdated"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@neondatabase/serverless": "0.10.4",
    "@prisma/client": "5.22.0",
    "@tanstack/react-query": "^5.62.0",
    "argon2": "0.41.1",
    "date-fns": "^4.4.0",
    "iron-session": "8.0.4",
    "jose": "5.9.6",
    "mercadopago": "2.0.15",
    "next": "15.5.18",
    "otpauth": "^9.5.1",
    "qrcode": "^1.5.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.54.0",
    "resend": "4.0.0",
    "transbank-sdk": "6.1.1",
    "zod": "3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.18",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "playwright": "^1.49.1",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "prisma": "5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vite": "^8.0.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "rollup@>=3.0.0 <3.30.0": "^3.30.0",
      "postcss@8.4.31": "^8.5.10",
      "uuid": "^11.1.1",
      "form-data": "^4.0.6"
    }
  }
}
