generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── USUARIOS Y AUTENTICACIÓN ─────────────────────────────

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  role         Role    @default(CLIENT)
  firstName    String?
  lastName     String?
  phone        String? // cifrado AES-256-GCM

  // Consentimiento Ley 21.719
  consentEssential Boolean
  consentMarketing Boolean  @default(false)
  consentVersion   String
  consentAt        DateTime
  consentIp        String?
  consentUpdatedAt DateTime?

  // Doble factor TOTP (RFC 6238) — el secreto se guarda cifrado AES-256-GCM.
  // totpEnabledAt null + secreto presente = enrolamiento pendiente de confirmar
  totpSecret    String?
  totpEnabledAt DateTime?

  emailVerified DateTime?
  lastLoginAt   DateTime?
  failedLogins  Int       @default(0)
  lockedUntil   DateTime?
  // Se incrementa al cerrar sesión: invalida todos los refresh tokens emitidos antes
  tokenVersion  Int       @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  orders    Order[]
  addresses Address[]

  @@index([email])
  @@index([role])
}

// Dos roles, principio de mínimo privilegio: el CLIENT compra y gestiona SUS
// datos; el SELLER opera la tienda. No existe superusuario con acceso total.
enum Role {
  CLIENT
  SELLER
}

// ─── CATÁLOGO ─────────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  active      Boolean   @default(true)
  order       Int       @default(0)
  archivedAt  DateTime?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id                 String    @id @default(cuid())
  sku                String    @unique
  slug               String    @unique
  name               String
  nameKorean         String?
  description        String
  priceCLP           Int
  stock              Int       @default(0)
  lowStockThreshold  Int       @default(5)
  costCLP            Int?
  weightGrams        Int
  images             String[]
  active             Boolean   @default(true)
  archivedAt         DateTime?
  featured           Boolean   @default(false)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  orderItems   OrderItem[]
  reservations StockReservation[]
  movements    StockMovement[]
  adjustments  StockAdjustment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([active, archivedAt])
  @@index([slug])
  @@index([stock])
}

// ─── DIRECCIONES Y ÓRDENES ────────────────────────────────

model Address {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id])

  fullName  String
  street    String
  number    String
  apartment String?
  commune   String
  region    String
  phone     String
  notes     String?
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
}

model StockReservation {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  quantity  Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([orderId, productId])
  @@index([productId, expiresAt])
  @@index([expiresAt])
}

model StockMovement {
  id             String              @id @default(cuid())
  productId      String
  product        Product             @relation(fields: [productId], references: [id])
  type           StockMovementType
  reason         StockMovementReason
  quantity       Int
  previousStock  Int
  resultingStock Int
  orderId        String?
  order          Order?              @relation(fields: [orderId], references: [id])
  adjustmentId   String?
  adjustment     StockAdjustment?    @relation(fields: [adjustmentId], references: [id])
  actorId        String?
  notes          String?
  createdAt      DateTime            @default(now())

  @@index([productId, createdAt])
  @@index([orderId])
  @@index([type, createdAt])
}

enum StockMovementType {
  IN
  OUT
}

enum StockMovementReason {
  SALE
  RESTOCK
  CORRECTION_UP
  CORRECTION_DOWN
  DAMAGED
  EXPIRED
  RETURNED
  INITIAL_LOAD
}

model StockAdjustment {
  id            String              @id @default(cuid())
  productId     String
  product       Product             @relation(fields: [productId], references: [id])
  previousStock Int
  newStock      Int
  delta         Int
  reason        StockMovementReason
  notes         String?
  actorId       String
  createdAt     DateTime            @default(now())
  movements     StockMovement[]

  @@index([productId, createdAt])
  @@index([actorId])
}

model Order {
  id          String @id @default(cuid())
  orderNumber Int    @unique @default(autoincrement())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  items          OrderItem[]
  stockMovements StockMovement[]
  reservations   StockReservation[]

  subtotalCLP Int
  shippingCLP Int
  totalCLP    Int

  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  paymentProvider String?
  paymentRef      String?
  paidAt          DateTime?

  // Solo datos necesarios para el despacho Starken — sin email (ya está en user.email)
  shippingFullName  String
  shippingStreet    String
  shippingNumber    String
  shippingApartment String?
  shippingCommune   String
  shippingRegion    String
  shippingPhone     String
  shippingNotes     String?

  trackingNumber String?
  shippedAt      DateTime?
  deliveredAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity     Int
  unitPriceCLP Int
  productName  String

  @@index([orderId])
}

// ─── COMPLIANCE Y SEGURIDAD ───────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorRole  String?
  action     String
  targetType String?
  targetId   String?
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

// Registro de incidencias de ciberseguridad — Ley 21.663 (Marco de Ciberseguridad),
// Ley 21.459 (Delitos Informáticos) y Ley 21.719 (Protección de Datos Personales).
// Las incidencias y su bitácora son append-only: nunca se editan ni se borran,
// para que el registro sea oponible ante una auditoría o denuncia.
model SecurityIncident {
  id             String           @id @default(cuid())
  incidentNumber Int              @unique @default(autoincrement())
  title          String
  description    String
  category       IncidentCategory
  severity       IncidentSeverity
  status         IncidentStatus   @default(OPEN)
  detectedAt     DateTime

  // Ley 21.719: si afecta datos personales corre el deber de notificar a la Agencia
  affectsPersonalData   Boolean @default(false)
  affectedUsersEstimate Int?

  // Notificación a la autoridad (Agencia de Protección de Datos, CSIRT, PDI, Fiscalía)
  authorityName       String?
  authorityReportRef  String?
  authorityNotifiedAt DateTime?

  reportedBy String // actorId del usuario que registró la incidencia
  resolvedAt DateTime?

  events SecurityIncidentEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, severity])
  @@index([category])
  @@index([createdAt])
}

// Tipificación alineada con la Ley 21.459 sobre delitos informáticos
enum IncidentCategory {
  SYSTEM_INTEGRITY_ATTACK // Art. 1 — ataque a la integridad de un sistema informático
  UNAUTHORIZED_ACCESS     // Art. 2 — acceso ilícito
  ILLEGAL_INTERCEPTION    // Art. 3 — interceptación ilícita
  DATA_INTEGRITY_ATTACK   // Art. 4 — ataque a la integridad de los datos
  COMPUTER_FRAUD          // Art. 7 — fraude informático
  PERSONAL_DATA_BREACH    // Ley 21.719 — vulneración de datos personales
  PHISHING_IMPERSONATION  // suplantación / phishing a clientes o a la tienda
  CREDENTIAL_ABUSE        // uso abusivo de credenciales (fuerza bruta, stuffing)
  OTHER
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  CONTAINED
  RESOLVED
  REPORTED // denunciado / notificado a la autoridad
  CLOSED
}

// Bitácora encadenada por hash: cada evento sella el hash del anterior (SHA-256),
// de modo que cualquier alteración posterior rompe la cadena y es detectable.
model SecurityIncidentEvent {
  id         String            @id @default(cuid())
  incidentId String
  incident   SecurityIncident  @relation(fields: [incidentId], references: [id])
  seq        Int
  type       IncidentEventType
  detail     String
  actorId    String
  prevHash   String?
  hash       String

  createdAt DateTime @default(now())

  @@unique([incidentId, seq])
  @@index([incidentId, createdAt])
}

enum IncidentEventType {
  CREATED
  NOTE
  STATUS_CHANGE
  AUTHORITY_REPORT
  EVIDENCE
}

model ProcessedWebhook {
  id         String   @id
  provider   String
  receivedAt DateTime @default(now())

  @@index([provider, receivedAt])
}

model DataExportRequest {
  id          String    @id @default(cuid())
  userId      String
  requestedAt DateTime  @default(now())
  completedAt DateTime?
  downloadUrl String?
  expiresAt   DateTime?
}

model DeletionRequest {
  id           String    @id @default(cuid())
  userId       String
  requestedAt  DateTime  @default(now())
  scheduledFor DateTime
  executedAt   DateTime?
  reason       String?
}
